    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.2.0</Version>
    <AssemblyTitle>Served MCP Server</AssemblyTitle>
    <Description>MCP Server for AI assistants to interact with the Served platform</Description>
    <Authors>Served</Authors>
    <Company>Served</Company>
